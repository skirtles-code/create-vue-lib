{
  "private": true,
  "type": "module",
  "dependencies": {
    "vue": "^3.5.26"
  },
  "devDependencies": {
    <%_ if (config.includeTailwind) { _%>
    "@tailwindcss/vite": "^4.1.18",
    <%_ } _%>
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.4",
    "@vue/tsconfig": "^0.8.1",
    "npm-run-all2": "^8.0.4",
    <%_ if (config.includeVpRaw) { _%>
    "postcss": "^8.5.6",
    <%_ } _%>
    "rimraf": "^6.1.2",
