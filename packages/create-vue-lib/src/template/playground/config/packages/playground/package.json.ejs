{
  "private": true,
  "type": "module",
  "dependencies": {
    "vue": "$"
  },
  "devDependencies": {
    <%_ if (config.includeTailwind) { _%>
    "@tailwindcss/vite": "$",
    <%_ } _%>
    "@tsconfig/node24": "$",
    "@types/node": "$",
    "@vitejs/plugin-vue": "$",
    "@vue/tsconfig": "$",
    "npm-run-all2": "$",
    "rimraf": "$",
    <%_ if (config.includeTailwind) { _%>
    "tailwindcss": "$",
    <%_ } _%>
    "typescript": "$",
    "vite": "$",
    "vite-plugin-vue-devtools": "$",
    "vue-tsc": "$"
  },
  "scripts": {
    "clean": "rimraf dist",
    "dev": "vite --port 5051",
    "type-check": "vue-tsc --build",
    "build:only": "vite build",
    "build": "run-p -c type-check \"build:only {@}\" --",
    "preview": "vite preview --port 4051"
  }
}
