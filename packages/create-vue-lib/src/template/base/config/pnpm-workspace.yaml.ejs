packages:
  <%_ if (config.includePackagesDir) { _%>
  - '<%- config.packagesDir %>*'
  <%_ } else { _%>
  - '<%- config.mainPackageDirName %>'
  <%_ if (config.includeDocs) { _%>
  - 'docs'
  <%_ } _%>
  <%_ if (config.includePlayground) { _%>
  - 'playground'
  <%_ } _%>
  <%_ } _%>

ignoredBuiltDependencies:
  - simple-git-hooks

onlyBuiltDependencies:
<%_ if (config.includeTailwind) { _%>
  - '@tailwindcss/oxide'
<%_ } _%>
  - esbuild
